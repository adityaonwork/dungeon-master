{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stats and progress for the adventurer.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "level": { "type": "integer" },
        "xp": { "type": "integer" },
        "gold": { "type": "integer" },
        "charClass": { "type": "string", "enum": ["Warrior", "Mage", "Rogue", "Paladin"] },
        "challengeDays": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "level", "xp", "gold"]
    },
    "Quest": {
      "title": "Daily Quest",
      "description": "A task or challenge for the day.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "durationMinutes": { "type": "integer" },
        "timeSpent": { "type": "integer" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Failed"] },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard", "Epic"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status"]
    },
    "Achievement": {
      "title": "Epic Achievement",
      "description": "Milestones reached by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account data"
    },
    "/users/{userId}/quests/{questId}": {
      "schema": "Quest",
      "description": "Individual tasks for the user"
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "User achievements"
    },
    "/leaderboard/{userId}": {
      "schema": { "$ref": "entities/UserProfile" },
      "description": "Read-only copy for leaderboard"
    }
  }
}
